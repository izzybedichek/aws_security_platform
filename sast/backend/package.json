{
  "name": "sast-scanner",
  "version": "1.0.0",
  "description": "Static Application Security Testing (SAST) Scanner for Node.js applications",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "worker": "RUN_WORKER=true node server.js"
  },
  "keywords": [
    "sast",
    "security",
    "scanner",
    "vulnerability",
    "static-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/client-sqs": "^3.620.0",
    "@aws-sdk/client-ssm": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  }
}
